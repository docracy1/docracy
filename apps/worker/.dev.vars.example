# Copy to .dev.vars for local `wrangler dev` (this file is gitignored, .dev.vars.example is not).
# Any random string works locally — it just needs to stay the same across a signing chain's lifetime.
TOKEN_SECRET=dev-secret-change-me

# Overrides the production value in wrangler.toml [vars] for local dev only.
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_CONNECTOR_URL=http://localhost:8788

# Leave unset locally to have emails printed to the wrangler dev console instead of actually sent.
# RESEND_API_KEY=re_xxxxxxxx

# Billing (Stripe) — leave all three unset to have billing routes 501 gracefully. To test the
# checkout flow locally, use Stripe test-mode keys and `stripe listen --forward-to
# localhost:8787/api/billing/webhook` (prints the webhook signing secret to use below).
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# STRIPE_PRICE_ID=price_xxxxxxxx
