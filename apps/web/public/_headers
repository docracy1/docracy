# Cloudflare Pages custom headers. worker-src/script-src allow 'self' + blob: for pdf.js, which
# loads its worker from a same-origin bundled URL but can fall back to a Blob-wrapped worker.
# style-src needs 'unsafe-inline' because the whole app uses React inline style={{}} props, which
# compile to inline style="" attributes — CSP gates those the same as <style> tags.
/*
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'

# Vite-built assets are content-hashed (index-<hash>.js) — safe to cache for a year and mark
# immutable, unlike the HTML shell which must always revalidate.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
