# Cloudflare Pages custom headers. worker-src/script-src allow 'self' + blob: for pdf.js, which
# loads its worker from a same-origin bundled URL but can fall back to a Blob-wrapped worker.
# style-src needs 'unsafe-inline' because the whole app uses React inline style={{}} props, which
# compile to inline style="" attributes — CSP gates those the same as <style> tags.
/*
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'

# Vite-built assets are content-hashed (index-<hash>.js), but deliberately NOT marked `immutable`
# with a year-long max-age: Cloudflare Pages' deploy propagation isn't atomic across edge nodes, and
# a request landing on a not-yet-updated node can transiently get the SPA-fallback HTML (still a 200)
# for a brand new asset path. `immutable` would make a browser that caught that bad response cache it
# permanently with no way to self-correct. A moderate max-age bounds the worst case to a few hours
# instead of a year, while still avoiding a refetch on every load.
/assets/*
  Cache-Control: public, max-age=14400, must-revalidate

# RFC 8288 Link headers pointing agents/crawlers at real, existing resources — deliberately not an
# api-catalog link, since there's no /.well-known/api-catalog file behind it yet; /docs now has a
# genuine REST API reference section (see Docs.tsx), so service-doc is honest.
/
  Link: </docs>; rel="service-doc", </privacy>; rel="privacy-policy", </terms>; rel="terms-of-service"
