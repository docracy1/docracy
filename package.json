{
  "name": "docracy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "form-data": "^4.0.6"
  },
  "scripts": {
    "dev:worker": "npm run dev --workspace apps/worker",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:connector": "npm run dev --workspace apps/connector",
    "build:web": "npm run build --workspace apps/web",
    "deploy:worker": "npm run deploy --workspace apps/worker",
    "deploy:connector": "npm run deploy --workspace apps/connector",
    "test:worker": "npm run test --workspace apps/worker",
    "test:connector": "npm run test --workspace apps/connector",
    "test:shared": "npm run test --workspace packages/shared",
    "test:zapier": "npm run test --workspace apps/zapier",
    "test": "npm run test:shared && npm run test:worker && npm run test:connector && npm run test:zapier",
    "typecheck:worker": "npm run typecheck --workspace apps/worker",
    "typecheck:connector": "npm run typecheck --workspace apps/connector",
    "typecheck:shared": "npm run typecheck --workspace packages/shared",
    "typecheck:web": "npm run build --workspace apps/web",
    "typecheck": "npm run typecheck:shared && npm run typecheck:worker && npm run typecheck:connector && npm run typecheck:web"
  }
}
